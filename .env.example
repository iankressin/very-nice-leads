# Telegram MTProto (GramJS) — for channel monitoring
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# Telegram Bot (grammY) — for sending notifications
BOT_TOKEN=

# Anthropic — for LLM scoring
ANTHROPIC_API_KEY=

# LLM model (default: claude-sonnet-4-20250514)
LLM_MODEL=claude-sonnet-4-20250514

# Channel to monitor (Phase 1: single channel username, without @)
MONITORED_CHANNEL=

# Admin chat ID to receive alerts (Phase 1: single subscriber)
ADMIN_CHAT_ID=

# Relevance threshold (0-10, default: 5)
RELEVANCE_THRESHOLD=5

# Turso database
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
